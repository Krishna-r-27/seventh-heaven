#
# Local development (Vite mode=development)
# - Frontend runs at https://localhost:<vite_port>
# - API calls go to /api and are proxied to ASP.NET Core by vite.config.js
#
VITE_BASE_PATH=/
# true: "/" = under construction, storefront home at "/home". false: "/" = home.
VITE_UNDER_CONSTRUCTION=true
VITE_API_BASE=/api
# Cloudflare Turnstile (contact form). Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACtQYCQS5vlKHeH2

